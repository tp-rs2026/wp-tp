{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "loyalty_redesign/**",
              "ui_kits/consumer_app/**",
              "ui_kits/merchant_app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Noto Serif|Manrope))/i]",
        "message": "Font not provided by the design system. Available: Noto Serif, Manrope."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--bg",
      "--bg-inverse",
      "--bg-sunken",
      "--border",
      "--border-hairline",
      "--fg-1",
      "--fg-2",
      "--fg-on-dark",
      "--font-sans",
      "--font-serif",
      "--hit-min",
      "--radius-card",
      "--radius-card-lg",
      "--radius-code",
      "--radius-input",
      "--radius-pill",
      "--radius-sheet",
      "--shadow-editorial",
      "--shadow-receipt",
      "--space-lg",
      "--space-md",
      "--space-sm",
      "--space-xl",
      "--space-xs",
      "--space-xxl",
      "--tapara-error",
      "--tapara-neutral",
      "--tapara-primary",
      "--tapara-secondary",
      "--tapara-success",
      "--tapara-tag-pad",
      "--tapara-tertiary",
      "--tapara-white",
      "--text-body",
      "--text-body-sm",
      "--text-caption",
      "--text-display",
      "--text-h1",
      "--text-h2",
      "--text-h3",
      "--text-h4",
      "--text-label",
      "--text-micro",
      "--text-overline",
      "--track-button",
      "--track-micro",
      "--track-overline",
      "--weight-bold",
      "--weight-medium",
      "--weight-regular"
    ],
    "tokenKinds": {
      "--tapara-primary": "color",
      "--tapara-secondary": "color",
      "--tapara-tertiary": "color",
      "--tapara-neutral": "color",
      "--tapara-white": "color",
      "--tapara-success": "color",
      "--tapara-error": "color",
      "--tapara-tag-pad": "spacing",
      "--fg-1": "color",
      "--fg-2": "color",
      "--fg-on-dark": "color",
      "--bg": "color",
      "--bg-sunken": "color",
      "--bg-inverse": "color",
      "--border": "color",
      "--border-hairline": "color",
      "--font-serif": "font",
      "--font-sans": "font",
      "--text-display": "font",
      "--text-h1": "font",
      "--text-h2": "font",
      "--text-h3": "font",
      "--text-h4": "font",
      "--text-body": "font",
      "--text-body-sm": "font",
      "--text-label": "font",
      "--text-caption": "font",
      "--text-overline": "font",
      "--text-micro": "font",
      "--weight-regular": "font",
      "--weight-medium": "font",
      "--weight-bold": "font",
      "--track-overline": "spacing",
      "--track-micro": "spacing",
      "--track-button": "spacing",
      "--space-xs": "spacing",
      "--space-sm": "spacing",
      "--space-md": "spacing",
      "--space-lg": "spacing",
      "--space-xl": "spacing",
      "--space-xxl": "spacing",
      "--radius-pill": "radius",
      "--radius-card": "radius",
      "--radius-card-lg": "radius",
      "--radius-sheet": "radius",
